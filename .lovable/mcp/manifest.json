{
  "version": 1,
  "sdk_version": "0.22.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ilgoprsvztbqocbshtoe.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "fintrackplus-mcp",
      "version": "0.1.0",
      "title": "FinTrack⁺"
    },
    "tools": [
      {
        "name": "list_transactions",
        "title": "List transactions",
        "description": "List the signed-in user's FinTrack+ transactions. Optionally filter by type, project, or date range. Results are scoped to the caller's organization via RLS.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "type": {
              "description": "Filter by transaction type.",
              "type": "string",
              "enum": [
                "income",
                "expense"
              ]
            },
            "project_id": {
              "description": "Filter by project ID.",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "from_date": {
              "description": "Inclusive start date (YYYY-MM-DD).",
              "type": "string"
            },
            "to_date": {
              "description": "Inclusive end date (YYYY-MM-DD).",
              "type": "string"
            },
            "limit": {
              "description": "Max rows to return (default 50, max 200).",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_transaction",
        "title": "Create transaction",
        "description": "Create an income or expense entry in FinTrack+ for the signed-in user's organization. Amount is in the org's currency (INR).",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "income",
                "expense"
              ],
              "description": "Transaction type."
            },
            "amount": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Amount, must be positive."
            },
            "vendor": {
              "type": "string",
              "minLength": 1,
              "description": "Vendor or payer name."
            },
            "category_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Category ID (see list_categories)."
            },
            "payment_method": {
              "type": "string",
              "enum": [
                "cash",
                "online"
              ],
              "description": "Payment method."
            },
            "date": {
              "type": "string",
              "description": "Date in YYYY-MM-DD (local timezone)."
            },
            "time": {
              "description": "Time in HH:mm (24h). Defaults to now.",
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "project_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "handled_by": {
              "description": "Partner or company account handle.",
              "type": "string"
            },
            "notes": {
              "type": "string"
            },
            "is_gst": {
              "type": "boolean"
            }
          },
          "required": [
            "type",
            "amount",
            "vendor",
            "category_id",
            "payment_method",
            "date"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "financial_summary",
        "title": "Financial summary",
        "description": "Return total income, total expense, and net balance for the caller's organization in an optional date range. Excludes internal transfers by convention (transfers are typically tagged with the vendor 'Internal Transfer', 'Self Transfer', or 'Company Bank Account').",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "from_date": {
              "description": "Inclusive start date (YYYY-MM-DD).",
              "type": "string"
            },
            "to_date": {
              "description": "Inclusive end date (YYYY-MM-DD).",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_projects",
        "title": "List projects",
        "description": "List the caller's organization's projects (events).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "include_archived": {
              "description": "Include archived projects (default false).",
              "type": "boolean"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_categories",
        "title": "List categories",
        "description": "List available income/expense categories for the caller's organization.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "income",
                "expense"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_partners",
        "title": "List partners & accounts",
        "description": "List team partners and company bank accounts. Use their handle (user_id for members, id for company accounts) as `handled_by` on transactions.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
